# =============================================================================
# Environment variables for Tin Tuc Next.js
# Copy to `.env.local` (or `.env`) and fill in real values. Secrets stay local.
# =============================================================================

# -----------------------------------------------------------------------------
# Site / public app
# -----------------------------------------------------------------------------

# Canonical site origin (no trailing slash). Used for SEO, Open Graph, sitemap,
# robots.txt, and JSON-LD. Defaults to https://example.com if unset — set this
# for production.
# Example: https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# When true, the front-end may use mock content instead of live APIs.
# Set to false when backend APIs / Supabase are ready.
NEXT_PUBLIC_USE_MOCKS=true

# Public API base URL for client fetches (no trailing slash).
# Leave empty to use relative `/api` (same origin) in admin; public http client
# requires this when not relying on relative paths.
# Example: http://localhost:3000/api  or  https://your-domain.com/api
NEXT_PUBLIC_API_BASE_URL=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Project URL from Supabase dashboard → Settings → API
# Example: https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) key — safe for the browser; RLS must protect data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server only. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Admin / cron secrets (server only)
# -----------------------------------------------------------------------------

# Server-to-server admin auth (cron jobs, internal scripts, QStash-style callers).
# Admin UI uses Supabase session cookies, not this secret.
# Generate: openssl rand -hex 32
ADMIN_API_SECRET=

# Protects GET /api/cron/flush. Send as: Authorization: Bearer <CRON_SECRET>
# Required in production; if unset, the route may run without auth (dev only).
# Generate: openssl rand -hex 32
CRON_SECRET=

# -----------------------------------------------------------------------------
# Upstash Redis (rate limit, analytics counters, redirect cache versioning)
# -----------------------------------------------------------------------------

# From Upstash console → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Cloudflare R2 (media storage)
# -----------------------------------------------------------------------------

# Account ID from Cloudflare dashboard → R2
R2_ACCOUNT_ID=

# R2 API token credentials (Object Read & Write on the bucket)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name
R2_BUCKET_NAME=

# Public base URL for objects (custom domain or r2.dev public bucket URL).
# No trailing slash. Example: https://media.your-domain.com
R2_PUBLIC_URL=

# Same public base URL exposed to the client (CSP img-src / browser asset URLs).
# Usually identical to R2_PUBLIC_URL.
NEXT_PUBLIC_R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Optional developer tooling (not required at runtime)
# -----------------------------------------------------------------------------

# Set to "true" to enable @next/bundle-analyzer (or use: pnpm analyze).
# ANALYZE=true

# Override Next.js dist directory (dev script uses .next-dev on Windows).
# NEXT_DIST_DIR=.next
