# Add public environment variables here when the app needs them.
# Keep secrets in local .env files so they stay ignored by git.

# Mock data is enabled by default. Set this to false when backend APIs are ready.
NEXT_PUBLIC_USE_MOCKS=true

# Example: http://localhost:4000/api
NEXT_PUBLIC_API_BASE_URL=

# Admin API secret – used for server-to-server auth only (cron jobs, QStash).
# NOT meant for client-side usage (admin pages use Supabase session cookies).
# Generate a strong random value: openssl rand -hex 32
ADMIN_API_SECRET=
